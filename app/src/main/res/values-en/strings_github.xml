    <string name="github_strategy_guide_atom_con_2">Weaker support for private repositories and fine-grained metadata</string>
    <string name="github_strategy_guide_atom_requirement">No extra credential required</string>
    <string name="github_strategy_guide_api_summary">Uses Releases API. More structured and better for asset reads and private repositories.</string>
    <string name="github_strategy_guide_api_pro_1">More stable metadata and direct prerelease detection</string>
    <string name="github_strategy_guide_api_pro_2">Reads more release details and handles asset downloads more reliably</string>
    <string name="github_strategy_guide_api_con_1">Guest quota is low and can hit rate limits with many projects</string>
    <string name="github_strategy_guide_api_con_2">Access is limited when the token expires or lacks permissions</string>
    <string name="github_strategy_guide_api_requirement">Token optional; guest API is used when empty</string>
