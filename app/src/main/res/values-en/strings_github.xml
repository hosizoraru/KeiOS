    <string name="github_strategy_actions_guide_nightly_con_2">Best for latest successful runs; raw APK artifacts still need token fallback download</string>
    <string name="github_strategy_actions_guide_nightly_requirement">Public repository; workflow uploads artifacts; nightly.link can access the repository; zip artifacts are recommended</string>
